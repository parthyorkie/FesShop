#   "statusCode": 200,
#   "data": null,
#   "message": "Review deleted successfully"
# }

### ====================================================
### 📊 SOCIALPROOF APIs
### ====================================================
### The SocialProof feature tracks and broadcasts user activities 
### in real-time to create social validation and increase engagement.
### Events are automatically triggered by user actions and can be
### retrieved via REST APIs or received via WebSocket connection.

### ----------------------------------------------------
### 1. Get Recent Social Proof Events [PUBLIC]
# Retrieves the most recent social proof events
# Query Parameters:
#   - limit: Number of events to return (1-100, default: 10)
GET {{baseUrl}}/social-proof/recent?limit=20
Content-Type: application/json

### ----------------------------------------------------
### 2. Get Social Proof Metrics [PUBLIC]
# Returns aggregated metrics for today (UTC-based)
# Response includes:
#   - signupsToday: Number of new user registrations
#   - purchasesToday: Number of completed purchases
#   - reviewsToday: Number of product reviews submitted
#   - activeUsers: Count of unique users with any activity
GET {{baseUrl}}/social-proof/metrics
Content-Type: application/json

### ====================================================
### 🔌 WEBSOCKET CONNECTION (Socket.IO)
### ====================================================
### WebSocket URL: ws://localhost:3000
### 
### The SocialProof feature uses WebSocket for real-time event broadcasting.
### Events are automatically sent to all connected clients when users:
### - Sign up (SIGNUP event)
### - Make a purchase (PURCHASE event)  
### - Submit a review (REVIEW event)
### - View products (VIEW event)
### - Come online (ONLINE_USER event)
###
### CLIENT IMPLEMENTATION EXAMPLE:
### ```javascript
### import io from 'socket.io-client';
### 
### // Connect to WebSocket server
### const socket = io('http://localhost:3000', {
###   transports: ['websocket'],
###   cors: {
###     origin: process.env.CORS_ORIGIN || '*'
###   }
### });
### 
### // Listen for connection
### socket.on('connect', () => {
###   console.log('Connected to SocialProof WebSocket');
### });
### 
### // Listen for new social proof events
### socket.on('social-proof:new', (data) => {
###   console.log('New activity:', data);
###   // data structure:
###   // {
###   //   id: "507f1f77bcf86cd799439011",
###   //   message: "John Doe joined recently",
###   //   createdAt: "2024-01-15T10:30:00Z"
###   // }
### });
### 
### // Handle disconnection
### socket.on('disconnect', () => {
###   console.log('Disconnected from WebSocket');
### });
### 
### // Handle errors
