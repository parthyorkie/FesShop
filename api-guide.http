### ----------------------------------------------------
### 3. Get Single Order [PUBLIC/USER]
# Requires: valid order ID (24-char hex)
# Response: 200 OK with complete order object or 404 if not found
GET {{baseUrl}}/orders/{{orderId}}
Content-Type: application/json

### ----------------------------------------------------
### 4. Update Order [ADMIN]
# Requires: valid order ID, optional fields to update
# Can update: customer, customerSnapshot, items, discount, festival, paymentMethod, paymentStatus
# At least one field is required
PUT {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "customerSnapshot": {
    "name": "John Doe Updated",
    "phone": "9876543210"
  },
  "discount": 75.00,
  "paymentStatus": "PAID",
  "paymentMethod": "UPI"
}

### ----------------------------------------------------
### 5. Delete Order - Soft Delete [ADMIN]
# Requires: valid order ID
# Order data is preserved but marked as deleted
DELETE {{baseUrl}}/orders/{{orderId}}
Authorization: Bearer {{token}}
Content-Type: application/json

### ----------------------------------------------------
### 6. Reorder [ADMIN]
# Creates a new order from an existing order
# Requires: valid order ID from previous order
# Optional: paymentMethod, paymentStatus (can be different from original)
POST {{baseUrl}}/orders/reorder/{{orderId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "paymentMethod": "CARD",
  "paymentStatus": "PENDING"
}



### 1. Create Section [ADMIN]
# Type must be one of: "banner", "grid", "horizontal"
# DataSource is required (e.g., static or dynamic)
# Discriminator-specific fields:
# - banner: items [{ image, cta: { type: "product"|"category", value: ID } }]
# - grid: columns, items [{ title, image, cta: { type, value } }]
# - horizontal: items [{ title, image, cta: { type, value } }]
POST {{baseUrl}}/sections
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "type": "banner",
  "title": "Summer Sale Banner",
  "displayOrder": 1,
  "status": "published",
  "isActive": true,
  "dataSource": {
    "type": "static"
  },
  "items": [
    {
      "image": "https://example.com/banner1.jpg",
      "cta": {
        "type": "category",
        "value": "{{categoryId}}"
      }
    }
  ]
}

### ----------------------------------------------------
### 2. List Sections [PUBLIC/USER]
# Supports optional queries for filtering/pagination
GET {{baseUrl}}/sections?page=1&limit=10
Content-Type: application/json

### ----------------------------------------------------
### 3. Get Single Section [PUBLIC/USER]
GET {{baseUrl}}/sections/{{sectionId}}
Content-Type: application/json

### ----------------------------------------------------
### 4. Update Section [ADMIN]
PUT {{baseUrl}}/sections/{{sectionId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "title": "Updated Summer Banner",
  "status": "published",
  "displayOrder": 2
}

### ----------------------------------------------------
### 5. Delete Section [ADMIN]
DELETE {{baseUrl}}/sections/{{sectionId}}
Authorization: Bearer {{token}}
Content-Type: application/json

### ====================================================
### 👥 USER MANAGEMENT APIs [ADMIN ONLY]

### 1. Create User [ADMIN]
# Creates a new user with hashed password
POST {{baseUrl}}/users
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Jane Smith",
  "email": "jane@example.com",
  "password": "SecurePass123",
  "role": "USER"
}

### ----------------------------------------------------
### 2. List All Users [ADMIN]
# Supports optional queries: ?page=1&limit=10&search=jane&role=USER&startDate=2024-01-01&endDate=2024-12-31
GET {{baseUrl}}/users?page=1&limit=10
Authorization: Bearer {{token}}
Content-Type: application/json

### ----------------------------------------------------
### 3. Get Single User [ADMIN]
GET {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}
Content-Type: application/json

### ----------------------------------------------------
### 4. Update User [ADMIN]
# Can update: name, email, role
# Cannot update password through this endpoint (use change-password instead)
PUT {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Jane Doe Smith",
  "role": "ADMIN"
}

### ----------------------------------------------------
### 5. Delete User - Soft Delete [ADMIN]
# User data is preserved but marked as deleted
DELETE {{baseUrl}}/users/{{userId}}
Authorization: Bearer {{token}}
Content-Type: application/json

### ----------------------------------------------------
### 6. Change Password [AUTHENTICATED USER]
# Any authenticated user can change their own password
# Requires old password verification
POST {{baseUrl}}/users/change-password
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "oldPassword": "CurrentPassword123",
  "newPassword": "NewPassword456"
}

### ====================================================
### ⭐ REVIEW APIs
### ====================================================

### 1. Create Review [AUTHENTICATED]
# Creates a new product review
# Required: userId (ObjectId), productId (ObjectId), rating (1-5)
# Optional: comment (max 1000 chars)
# Note: This triggers a REVIEW social proof event
# Response: 201 Created with review object
POST {{baseUrl}}/reviews
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "userId": "{{userId}}",
  "productId": "{{productId}}",
  "rating": 5,
  "comment": "Excellent product! Highly recommended."
}

### RESPONSE EXAMPLE:
# HTTP/1.1 201 Created
# {
#   "statusCode": 201,
#   "data": {
#     "_id": "507f1f77bcf86cd799439011",
#     "userId": "507f1f77bcf86cd799439012",
#     "productId": "507f1f77bcf86cd799439013",
#     "rating": 5,
#     "comment": "Excellent product! Highly recommended.",
#     "isDeleted": false,
#     "createdAt": "2024-05-11T10:30:00.000Z",
#     "updatedAt": "2024-05-11T10:30:00.000Z",
#     "__v": 0
#   },
#   "message": "Review created successfully"
# }

### ----------------------------------------------------
### 2. List Reviews [PUBLIC]
# Retrieves reviews with optional filtering and pagination
# Query Parameters:
#   - page: Page number (default: 1)
#   - limit: Items per page (1-100, default: 10)
#   - productId: Filter by product ID
#   - userId: Filter by user ID
# Response: 200 OK with paginated reviews array
GET {{baseUrl}}/reviews?page=1&limit=10
Content-Type: application/json

### List Reviews by Product
GET {{baseUrl}}/reviews?productId={{productId}}&page=1&limit=10
Content-Type: application/json

### List Reviews by User
GET {{baseUrl}}/reviews?userId={{userId}}&page=1&limit=10
Content-Type: application/json

