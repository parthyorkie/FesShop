#     "hasPrevPage": false
#   }
# }

### ----------------------------------------------------
### 3. Get Single Review [PUBLIC]
# Requires: valid review ID (24-char hex)
# Response: 200 OK with review object or 404 if not found
GET {{baseUrl}}/reviews/{{reviewId}}
Content-Type: application/json

### RESPONSE EXAMPLE:
# HTTP/1.1 200 OK
# {
#   "statusCode": 200,
#   "data": {
#     "_id": "507f1f77bcf86cd799439011",
