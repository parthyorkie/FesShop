###   console.error('WebSocket error:', error);
### });
### ```
###
### REACT NATIVE IMPLEMENTATION:
### ```javascript
### import io from 'socket.io-client';
### import { useEffect, useState } from 'react';
### 
### const useSocialProof = () => {
###   const [events, setEvents] = useState([]);
###   const [isConnected, setIsConnected] = useState(false);
### 
###   useEffect(() => {
###     const socket = io('http://your-api-url.com');
###     
###     socket.on('connect', () => setIsConnected(true));
###     socket.on('disconnect', () => setIsConnected(false));
###     
###     socket.on('social-proof:new', (event) => {
###       setEvents(prev => [event, ...prev].slice(0, 50));
###       // Show notification or update UI
###     });
### 
###     return () => socket.disconnect();
###   }, []);
### 
###   return { events, isConnected };
### };
### ```
###


### ====================================================
### 📝 SOCIALPROOF EVENT TYPES
### ====================================================
### The following event types are automatically tracked:
### 
### 1. SIGNUP - When a new user registers
###    Message format: "{userName} joined recently"
###    Triggered in: /auth/register endpoint
###
### 2. PURCHASE - When a user completes an order
###    Message format: "{userName} completed a purchase"
###    Triggered in: Order creation/completion
###
### 3. REVIEW - When a user submits a product review
###    Message format: "{userName} left a review"
###    Triggered in: Review creation endpoint
###
### 4. VIEW - When a user views a product (future)
###    Message format: "{userName} is viewing a product"
###    
### 5. ONLINE_USER - When a user comes online (future)
###    Message format: "{userName} is online"

### ====================================================
### 🔄 SOCIALPROOF INTEGRATION NOTES
### ====================================================
### 
### AUTOMATIC TRIGGERS:
### - Events are automatically triggered by user actions
### - No manual API calls needed to create events
### - Broadcasting happens in real-time via WebSocket
### 
### PRIVACY & SECURITY:
### - User names are anonymized as "Someone" if not available
### - No sensitive data is exposed in events
### - Rate limiting prevents spam (100 events/hour per user)
### - Events older than 1 hour are cleaned from broadcast cache
###
### ERROR HANDLING:
### - Social proof failures don't break main operations
### - Events continue even if WebSocket is disconnected
### - Duplicate broadcasts are prevented automatically
###
### PERFORMANCE:
### - Events are indexed for fast retrieval
### - WebSocket uses efficient binary protocol
### - Metrics are cached and updated periodically
### - In-memory cache prevents duplicate broadcasts
